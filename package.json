{
  "name": "qrohl",
  "version": "1.1.12",
  "description": "QR and barcode generation tool",
  "homepage": "https://github.com/kanishkaGayan/Qrohl",
  "author": {
    "name": "Kanishka Meddegoda",
    "email": "gayanmedde2022@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kanishkaGayan/Qrohl.git"
  },
  "private": true,
  "main": "electron/main.mjs",
  "productName": "Qrohl",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "dev:electron": "concurrently -k \"npm:dev\" \"npm:electron:dev\"",
    "electron:dev": "wait-on tcp:3000 && cross-env LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 LANGUAGE=en_US DATABASE_URL=file:./dev.db electron .",
    "prepare:packaging": "node scripts/prepare-packaged-next.mjs",
    "electron:assets": "node scripts/generate-electron-assets.mjs",
    "build:electron": "npm run build && npm run prepare:packaging && npm run electron:assets && electron-builder --win nsis appx --publish never",
    "build:appimage": "npm run build && npm run prepare:packaging && npm run electron:assets && electron-builder --linux AppImage --publish never",
    "package:linux": "npm run build && npm run prepare:packaging && npm run electron:assets && electron-builder --linux --publish never",
    "package:all": "npm run build && npm run prepare:packaging && npm run electron:assets && electron-builder --win --linux --publish never",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "prisma": "^6.18.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-barcode": "^1.6.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^38.3.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "sharp": "^0.34.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.2"
  },
  "build": {
    "appId": "com.qrohl.desktop",
    "productName": "Qrohl",
    "asar": false,
    "copyright": "Copyright © 2026 Kanishka Meddegoda",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      ".next/node_modules/**/*",
      "!.next/dev/**/*",
      "!.next/cache/**/*",
      ".prisma/**/*",
      "node_modules/@prisma/**/*",
      "public/**/*",
      "package.json",
      "next.config.ts"
    ],
    "extraMetadata": {
      "main": "electron/main.mjs"
    },
    "win": {
      "target": [
        "nsis",
        "appx"
      ],
      "icon": "public/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "maintainer": "Kanishka Meddegoda <gayanmedde2022@gmail.com>",
      "vendor": "Kanishka Meddegoda",
      "icon": "public/icon.png",
      "desktop": {
        "entry": {
          "Name": "Qrohl",
          "Comment": "QR and barcode generation tool",
          "Categories": "Utility;Graphics;",
          "Keywords": "qr;barcode;generator;"
        }
      }
    },
    "appImage": {
      "category": "Utility"
    },
    "appx": {
      "applicationId": "Qrohl",
      "displayName": "Qrohl",
      "publisherDisplayName": "Kanishka Meddegoda",
      "identityName": "KanishkaMeddegoda.Qrohl",
      "publisher": "CN=Kanishka Meddegoda",
      "backgroundColor": "#111827",
      "defaultLanguage": "en-US",
      "setBuildNumber": false,
      "capabilities": ["runFullTrust"]
    }
  }
}
